{
  "manifest_version": 3,
  "name": "Diffy — PR Command Center",
  "version": "0.1.0",
  "description": "A draggable GitHub PR companion for grounded Q&A, durable follow-ups, and fast voice-to-patch changes.",
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Diffy — PR review activity",
    "default_popup": "popup.html"
  },
  "commands": {
    "record-on-pr": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Diffy: apply spoken changes on the current PR"
    }
  },
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": [
        "anchors.js",
        "recovery.js",
        "hub.js",
        "timer.js",
        "diffy-state.js",
        "storage.js",
        "diffy-launcher.js",
        "diffy-command-center.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["gaze.html", "gaze.css", "gaze.js", "vendor/webgazer.js"], "matches": ["https://github.com/*"] }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' http://localhost:4100 https://tfhub.dev https://www.kaggle.com https://storage.googleapis.com;"
  },
  "host_permissions": [
    "http://localhost:4100/*",
    "https://tfhub.dev/*",
    "https://www.kaggle.com/*",
    "https://storage.googleapis.com/*"
  ]
}
